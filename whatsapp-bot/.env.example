# 248 WhatsApp Bot — environment config
# Copy to .env and fill in your values

# Supabase — use SERVICE_ROLE key (not anon key)
SUPABASE_URL=https://wqmciwieiqvnswvspdyz.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# VectorEngine / Claude API
VECTORENGINE_API_KEY=your_vectorengine_key_here
VECTORENGINE_BASE_URL=https://api.vectorengine.ai

# Admin WhatsApp numbers — country code + number, no +, comma separated
# e.g. 85264274620,85291234567
ADMIN_PHONES=85264274620

# Shared secret between this bot and the Next.js app
WEBHOOK_SECRET=generate_a_random_string_here

# Port for the Express API server
PORT=3001

# Puppeteer Chrome path — set on Render if auto-detection fails
# e.g. /usr/bin/chromium-browser
PUPPETEER_EXECUTABLE_PATH=
